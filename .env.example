# Copy to .env for local testing — never commit .env to git.
# For sandbox testing set PADDLE_SANDBOX=true and use sandbox price IDs / secrets.
# For production set PADDLE_SANDBOX=false (or omit it) and use live price IDs / secrets.

# From Paddle dashboard > Notifications > your webhook endpoint
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# Must exactly match AETHELGARD_LICENSE_SECRET used to build the app binary.
# Generate with: openssl rand -base64 32
AETHELGARD_LICENSE_SECRET=

# From resend.com dashboard
RESEND_API_KEY=re_...

# Paddle API key — from Paddle dashboard > Developer Tools > Authentication
# Use sandbox key when PADDLE_SANDBOX=true, live key otherwise
PADDLE_API_KEY=

# Set to "true" to use sandbox.paddle.com instead of api.paddle.com
PADDLE_SANDBOX=false

# Paddle price IDs — find these in Paddle dashboard > Catalog > Prices
# Annual subscription prices
PADDLE_PERSONAL_PRICE_ID=pri_...
PADDLE_SOVEREIGN_PRICE_ID=pri_...
PADDLE_CORPORATE_PRICE_ID=pri_...

# Lifetime prices
PADDLE_PERSONAL_LIFETIME_PRICE_ID=pri_...
PADDLE_SOVEREIGN_LIFETIME_PRICE_ID=pri_...
PADDLE_CORPORATE_LIFETIME_PRICE_ID=pri_...
