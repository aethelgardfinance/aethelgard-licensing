{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022", "WebWorker"],
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "rootDir": "."
    },
    "include": ["api/**/*", "lib/**/*"],
    "exclude": ["node_modules", "dist"]
}
