{
    "name": "aethelgard-licensing",
    "version": "1.0.0",
    "private": true,
    "description": "Paddle webhook receiver — generates and delivers Aethelgard license keys via Resend.",
    "type": "module",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "test:crypto": "node --test lib/__tests__/keygen.test.mjs",
        "test:crypto-pdfstudio": "node --test lib/__tests__/keygen-pdfstudio.test.mjs",
        "test:activation": "node --loader ts-node/esm lib/__tests__/activation.test.ts",
        "test": "npm run test:crypto && npm run test:crypto-pdfstudio && npm run test:activation"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@vercel/node": "^5.7.13",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.0"
    },
    "dependencies": {
        "@upstash/redis": "^1.37.0"
    },
    "overrides": {
        "path-to-regexp": "^8.2.0",
        "undici":         "^7.16.0",
        "minimatch":      "^10.2.5",
        "ajv":            "^8.17.2",
        "smol-toml":      "^1.6.1"
    }
}
